pkgname = linux-hC
	pkgdesc = The Linux BORE + LTO + ZEN/Cachy/Clear Tweaks + Custom set of build flags Clang 21 improved hC-kernel kernel and modules
	depends = coreutils
	depends = kmod
	depends = initramfs
	optdepends = wireless-regdb: to set the correct wireless channels of your country
	optdepends = linux-firmware: firmware images needed for some devices
	optdepends = modprobed-db: Keeps track of EVERY kernel module that has ever been probed - useful for those of us who make localmodconfig
	optdepends = scx-scheds: to use sched-ext schedulers
	provides = VIRTUALBOX-GUEST-MODULES
	provides = WIREGUARD-MODULE
	provides = KSMBD-MODULE
	provides = NTSYNC-MODULE

pkgname = linux-hC-headers
	pkgdesc = Headers and scripts for building modules for the Linux BORE + LTO + ZEN/Cachy/Clear Tweaks + Custom set of build flags Clang 21 improved hC-kernel kernel
	depends = pahole
	depends = linux-hC
	depends = clang
	depends = llvm
	depends = lld
	provides = LINUX-HEADERS

pkgname = linux-hC-nvidia-open
	pkgdesc = nvidia open modules of 595.45.04 driver for the linux-hC kernel
	license = MIT AND GPL-2.0-only
	depends = linux-hC=6.19.8-1
	depends = nvidia-utils=595.45.04
	depends = libglvnd
	provides = NVIDIA-MODULE
	conflicts = linux-hC-nvidia

+/*
+ * Compute migration suitability score:
+ *   (runnable_avg - util_avg) * inv_weight * 960 >> 32
+ *
+ * Low score = heavy task with low starvation = ideal migration candidate:
+ *  - Heavy: small inv_weight, resolves imbalance efficiently
+ *  - Low starvation: small gap, well-served, unlikely to need re-migration
+ *
+ * Normalized to u16: 960 ≈ 65535 * 2^32 / (1024 * sched_prio_to_wmult[39])
+ * gives 65535 at nice 19 full contention.
+ */
+static inline u16 migrate_score(struct sched_entity *se)
+{
+	s32 gap = (s32)se->avg.runnable_avg - (s32)se->avg.util_avg;
+	gap &= ~(gap >> 31);
+
+	return (u16)(((u64)gap * se->load.inv_weight * 960) >> 32);
+}
+#endif /* CONFIG_SCHED_STARV_MIGRATE */

pkgname = linux-hC-rc
	pkgdesc = The Linux BORE + LTO + ZEN/Cachy/Clear Tweaks + Custom set of build flags Clang 21 improved hC-kernel - Release Candidate kernel and modules
	depends = coreutils
	depends = kmod
	depends = initramfs
	optdepends = wireless-regdb: to set the correct wireless channels of your country
	optdepends = linux-firmware: firmware images needed for some devices
	optdepends = modprobed-db: Keeps track of EVERY kernel module that has ever been probed - useful for those of us who make localmodconfig
	optdepends = scx-scheds: to use sched-ext schedulers
	provides = VIRTUALBOX-GUEST-MODULES
	provides = WIREGUARD-MODULE
	provides = KSMBD-MODULE
	provides = NTSYNC-MODULE

pkgname = linux-hC-rc-headers
	pkgdesc = Headers and scripts for building modules for the Linux BORE + LTO + ZEN/Cachy/Clear Tweaks + Custom set of build flags Clang 21 improved hC-kernel - Release Candidate kernel
	depends = binutils
	depends = glibc
	depends = libelf
	depends = libgcc
	depends = openssl
	depends = pahole
	depends = xxhash
	depends = zlib
	depends = zstd
	depends = linux-hC-rc
	depends = clang
	depends = llvm
	depends = lld
	provides = LINUX-HEADERS

pkgname = linux-hC-rc-nvidia-open
	pkgdesc = nvidia open modules of 595.71.05 driver for the linux-hC-rc kernel
	license = MIT AND GPL-2.0-only
	depends = linux-hC-rc=7.1.rc1-1
	depends = nvidia-utils=595.71.05
	depends = libglvnd
	provides = NVIDIA-MODULE
	conflicts = linux-hC-rc-nvidia
